{
    "dialogs": [
        {
            "text": "One day, a stranger came. When he left, something remained.",
            "wait_time": 4,
            "hide_dialog_after": false,
            "animation": "intro_1",
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "A stone. After that, things changed. People grew quiet.",
            "wait_time": 4,
            "hide_dialog_after": false,
            "animation": "intro_2",
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "The nights grew longer. And my mother… different. That night, she ran into the dark.",
            "wait_time": 4,
            "hide_dialog_after": false,
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "I remember her eyes... and the moment my father took his sword.",
            "wait_time": 5,
            "hide_dialog_after": false,
            "animation": "intro_3",
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "“Stay here,” he said. Then he disappeared into the night.",
            "wait_time": 4,
            "hide_dialog_after": false,
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "I waited. An hour. The wind still carries sounds from the village. My father hasn’t returned.",
            "wait_time": 5,
            "hide_dialog_after": false,
            "animation": "intro_4",
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "So now… I’m going after them.",
            "wait_time": 4,
            "hide_dialog_after": false,
            "portrait": "res://assets/sprites/headshots/player.png"
        }
    ]
}
