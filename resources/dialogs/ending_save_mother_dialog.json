{
    "dialogs": [
        {
            "text": "Mother! Look at me! The stone... it's cracking!",
            "wait_time": 4,
            "hide_dialog_after": false,
            "animation": "camera_pan",
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "Mina? Is that... is that you? The darkness... it's retreating... but it's so cold.",
            "wait_time": 5,
            "hide_dialog_after": false,
            "portrait": "res://assets/sprites/headshots/mother-healed-slightly-smiling.png"
        },
        {
            "text": "You're safe now. But father... he gave everything to hold back the shadows. He's... he's gone.",
            "wait_time": 5,
            "hide_dialog_after": false,
            "portrait": "res://assets/sprites/headshots/player.png"
        },
        {
            "text": "Hitoshi... no. I can still feel his warmth on the breeze. He traded his light for mine.",
            "wait_time": 5,
            "hide_dialog_after": false,
            "portrait": "res://assets/sprites/headshots/mother-healed-slightly-smiling.png"
        },
        {
            "text": "We have each other, mother. But the price of this mercy... I will feel it in my heart forever.",
            "wait_time": 5,
            "hide_dialog_after": true,
            "portrait": "res://assets/sprites/headshots/player.png"
        }
    ]
}
