[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/pause_menu.gd" id="1_pause"]

[node name="PauseMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_pause")

[node name="ColorRect" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.05, 0.75)

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Label" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "PAUSED"
horizontal_alignment = 1

[node name="ResumeButton" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Resume"

[node name="RestartButton" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Restart"

[node name="MainMenuButton" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "Main Menu"

[node name="DebugEndings" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 2
anchor_top = 1.0
anchor_bottom = 1.0
offset_top = -101.0
offset_right = 150.0
grow_vertical = 0
theme_override_constants/margin_left = 10
theme_override_constants/margin_bottom = 10

[node name="VBoxContainer" type="VBoxContainer" parent="DebugEndings"]
layout_mode = 2

[node name="SaveFatherDebug" type="Button" parent="DebugEndings/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "DEBUG: Save Father"

[node name="SaveMotherDebug" type="Button" parent="DebugEndings/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "DEBUG: Save Mother"

[node name="SaveBothDebug" type="Button" parent="DebugEndings/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "DEBUG: Save Both"

[node name="SaveNoneDebug" type="Button" parent="DebugEndings/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "DEBUG: Save None (Fail)"

[connection signal="pressed" from="CenterContainer/VBoxContainer/ResumeButton" to="." method="_on_resume_button_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/RestartButton" to="." method="_on_restart_button_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/MainMenuButton" to="." method="_on_main_menu_button_pressed"]
[connection signal="pressed" from="DebugEndings/VBoxContainer/SaveFatherDebug" to="." method="_on_save_father_debug_pressed"]
[connection signal="pressed" from="DebugEndings/VBoxContainer/SaveMotherDebug" to="." method="_on_save_mother_debug_pressed"]
[connection signal="pressed" from="DebugEndings/VBoxContainer/SaveBothDebug" to="." method="_on_save_both_debug_pressed"]
[connection signal="pressed" from="DebugEndings/VBoxContainer/SaveNoneDebug" to="." method="_on_save_none_debug_pressed"]
